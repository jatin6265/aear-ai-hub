# ─── Supabase (Frontend) ──────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_XXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── Supabase (Worker / Backend) ─────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_ACCESS_TOKEN=sbp_XXXXXXXXXXXX   # Personal Access Token (not committed to git)

# ─── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-XXXXXXXXXX
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ─── Worker Auth ─────────────────────────────────────────────────────────────
CONNECTOR_WORKER_TOKEN=generate_a_32+_char_random_hex_string_here

# ─── Redis (Railway Redis plugin URL) ────────────────────────────────────────
REDIS_URL=redis://default:PASSWORD@HOST:PORT

# ─── Agent Runtime ───────────────────────────────────────────────────────────
# Use "builtin" in production (no openclaw install required).
# Switch to "openclaw" only if openclaw CLI is installed in your deployment environment.
AGENT_RUNTIME_ENGINE=builtin

# ─── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=re_XXXXXXXXXXXX
RESEND_FROM_EMAIL=info@yourdomain.com

# ─── Frontend origin (for email links / invite redirects) ────────────────────
INVITE_APP_BASE_URL=https://your-production-domain.vercel.app

# ─── Stripe (billing) ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_XXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXX

# ─── Razorpay (billing – India) ──────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXX
RAZORPAY_WEBHOOK_SECRET=XXXXXXXXXXXX

# ─── Encryption (connector credentials at rest) ──────────────────────────────
CONNECTOR_ENCRYPTION_KEY=generate_a_32+_char_random_hex_string
CONNECTOR_ENCRYPTION_KEY_VERSION=1

# ─── Webhook signing ─────────────────────────────────────────────────────────
WEBHOOK_SIGNING_SECRET=generate_a_32+_char_random_hex_string
